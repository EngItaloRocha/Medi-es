{
  "name": "CustoFixo",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome do custo fixo"
    },
    "categoria": {
      "type": "string",
      "enum": [
        "Administrativo",
        "Servi\u00e7os",
        "Tecnologia",
        "Impostos",
        "Equipamentos",
        "Seguros",
        "Outros"
      ],
      "default": "Administrativo"
    },
    "frequencia": {
      "type": "string",
      "enum": [
        "Mensal",
        "Anual",
        "Trimestral",
        "Semestral"
      ],
      "default": "Mensal"
    },
    "dia_vencimento": {
      "type": "number",
      "description": "Dia do m\u00eas do vencimento"
    },
    "obra_id": {
      "type": "string",
      "description": "ID da obra (se associado a obra)"
    },
    "obra_name": {
      "type": "string",
      "description": "Nome da obra ou 'Empresa'"
    },
    "valor": {
      "type": "number",
      "default": 0
    },
    "status": {
      "type": "string",
      "enum": [
        "Ativo",
        "Inativo"
      ],
      "default": "Ativo"
    }
  },
  "required": [
    "name",
    "valor"
  ]
}
